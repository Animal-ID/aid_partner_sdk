{
    "name": "animalid/partner-sdk",
    "description": "PHP SDK for the Animal ID Partner Integration API (dictionaries, owners, animals, procedures, photos).",
    "type": "library",
    "version": "1.1.0",
    "license": "MIT",
    "keywords": ["animal-id", "partner", "sdk", "api", "veterinary"],
    "homepage": "https://animal-id.net",
    "require": {
        "php": ">=7.3",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "autoload": {
        "psr-4": {
            "AnimalId\\PartnerSdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AnimalId\\PartnerSdk\\Tests\\": "tests/"
        }
    },
    "config": {
        "platform": {
            "php": "7.3.33"
        },
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-text"
    }
}
